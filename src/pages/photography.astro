import Layout from "@/layouts/Layout.astro";

const photos = Array.from({ length: 16 }, (_, index) => {
const number = index + 1;

return {
src: "/photos/" + number + ".JPG",
alt: "Photography by James Littlewood - image " + number,
};
});
---

<Layout
title="Photography | James Littlewood"
description="A selection of photography by James Littlewood."

>

  <div class="animate-in fade-in mx-auto w-full max-w-6xl p-8 duration-700 md:p-16">
    <header class="mb-10">
      <p class="text-xs font-medium uppercase tracking-[0.2em] text-muted-foreground">
