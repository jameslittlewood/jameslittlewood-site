```
  <h1 class="mt-3 text-3xl font-semibold tracking-tight md:text-4xl">
    Photography
  </h1>

  <p class="mt-4 max-w-2xl text-base leading-relaxed text-muted-foreground">
    A selection of photographs taken while exploring places, events and
    everyday moments.
  </p>
</header>

<section
  aria-label="Photography gallery"
  class="grid grid-cols-2 gap-3 sm:grid-cols-3 sm:gap-4 lg:grid-cols-4"
>
  {
    photos.map((photo) => (
      <button
        type="button"
        class="group block overflow-hidden rounded-xl border border-border bg-muted p-0 text-left"
        data-photo-src={photo.src}
        data-photo-alt={photo.alt}
        aria-label={"Expand " + photo.alt}
      >
        <img
          src={photo.src}
          alt={photo.alt}
          loading="lazy"
          decoding="async"
          class="block aspect-square w-full object-cover transition duration-500 ease-out group-hover:scale-105"
        />
      </button>
    ))
  }
</section>
