```

  </div>

  <script>
    const modal = document.getElementById("photo-modal");
    const expandedPhoto = document.getElementById("expanded-photo");
    const closeButton = document.getElementById("close-photo-modal");
    const backdropButton = document.getElementById("photo-modal-backdrop");
    const photoButtons = document.querySelectorAll("[data-photo-src]");

    if (
      modal instanceof HTMLElement &&
      expandedPhoto instanceof HTMLImageElement &&
      closeButton instanceof HTMLButtonElement &&
      backdropButton instanceof HTMLButtonElement
    ) {
      let previousBodyOverflow = "";

      const closePhotoModal = () => {
        modal.classList.add("hidden");
        modal.classList.remove("flex");
        modal.setAttribute("aria-hidden", "true");

        expandedPhoto.removeAttribute("src");
        expandedPhoto.alt = "";

        document.body.style.overflow = previousBodyOverflow;
      };

      photoButtons.forEach((button) => {
        if (!(button instanceof HTMLButtonElement)) {
          return;
        }

        button.addEventListener("click", () => {
          const photoSource = button.getAttribute("data-photo-src");
          const photoAlt = button.getAttribute("data-photo-alt") || "";

          if (photoSource === null) {
            return;
          }

          previousBodyOverflow = document.body.style.overflow;

          expandedPhoto.src = photoSource;
          expandedPhoto.alt = photoAlt;

          modal.classList.remove("hidden");
          modal.classList.add("flex");
          modal.setAttribute("aria-hidden", "false");

          document.body.style.overflow = "hidden";
        });
      });

      closeButton.addEventListener("click", closePhotoModal);
      backdropButton.addEventListener("click", closePhotoModal);

      document.addEventListener("keydown", (event) => {
        if (event.key === "Escape" && modal.classList.contains("flex")) {
          closePhotoModal();
        }
      });
    }
  </script>

</Layout>
