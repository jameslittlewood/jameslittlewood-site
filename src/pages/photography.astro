  </div>

  <script>
    const modal = document.getElementById("photo-modal");
    const expandedPhoto = document.getElementById("expanded-photo");
    const closeButton = document.getElementById("close-photo-modal");
    const backdropButton = document.getElementById("photo-modal-backdrop");
    const previousButton = document.getElementById("previous-photo");
    const nextButton = document.getElementById("next-photo");
    const photoButtons = Array.from(
      document.querySelectorAll("[data-photo-src]"),
    );

    if (
      modal instanceof HTMLElement &&
      expandedPhoto instanceof HTMLImageElement &&
      closeButton instanceof HTMLButtonElement &&
      backdropButton instanceof HTMLButtonElement &&
      previousButton instanceof HTMLButtonElement &&
      nextButton instanceof HTMLButtonElement
    ) {
      let currentIndex = 0;
      let previousBodyOverflow = "";

      const showPhoto = (index) => {
        if (photoButtons.length === 0) {
          return;
        }

        currentIndex =
          (index + photoButtons.length) % photoButtons.length;

        const button = photoButtons[currentIndex];
        const photoSource = button.getAttribute("data-photo-src");
        const photoAlt = button.getAttribute("data-photo-alt") || "";

        if (photoSource === null) {
          return;
        }

        expandedPhoto.src = photoSource;
        expandedPhoto.alt = photoAlt;
      };

      const openPhotoModal = (index) => {
        previousBodyOverflow = document.body.style.overflow;

        showPhoto(index);

        modal.classList.remove("hidden");
        modal.classList.add("flex");
        modal.setAttribute("aria-hidden", "false");

        document.body.style.overflow = "hidden";
        closeButton.focus();
      };

      const closePhotoModal = () => {
        modal.classList.add("hidden");
        modal.classList.remove("flex");
        modal.setAttribute("aria-hidden", "true");

        expandedPhoto.removeAttribute("src");
        expandedPhoto.alt = "";

        document.body.style.overflow = previousBodyOverflow;
      };

      photoButtons.forEach((button, index) => {
        button.addEventListener("click", () => {
          openPhotoModal(index);
        });
      });

      previousButton.addEventListener("click", () => {
        showPhoto(currentIndex - 1);
      });

      nextButton.addEventListener("click", () => {
        showPhoto(currentIndex + 1);
      });

      closeButton.addEventListener("click", closePhotoModal);
      backdropButton.addEventListener("click", closePhotoModal);

      document.addEventListener("keydown", (event) => {
        const modalIsOpen = modal.classList.contains("flex");

        if (!modalIsOpen) {
          return;
        }

        if (event.key === "Escape") {
          closePhotoModal();
        }

        if (event.key === "ArrowLeft") {
          showPhoto(currentIndex - 1);
        }

        if (event.key === "ArrowRight") {
          showPhoto(currentIndex + 1);
        }
      });
    }
  </script>

</Layout>
