---
import BaseLayout from '../layouts/BaseLayout.astro'
---

<BaseLayout>
	<main class="app-container pt-32 md:pt-40 pb-14 md:pb-20">
		<div class="max-w-4xl">
			<h1 class="text-5xl md:text-7xl font-bold leading-none">
				CV
			</h1>

			<p class="mt-6 text-xl max-w-2xl font-light leading-normal">
				James Littlewood — Technical Data Analyst
			</p>
		</div>
	</main>

	<section class="app-container pb-20 md:pb-28">
		<div class="max-w-4xl space-y-10 text-lg leading-relaxed">

			<section>
				<h2 class="section-title">Professional Profile</h2>
				<p class="mt-4">
					Detail-oriented data and technical operations professional with experience in
					product data quality, structured validation, categorisation, SQL analysis and
					stakeholder communication.
				</p>
			</section>

			<section>
				<h2 class="section-title">Core Skills</h2>
				<ul class="mt-4 list-disc pl-6 space-y-2">
					<li>Excel, Google Sheets, SQL, PostgreSQL and Snowflake fundamentals</li>
					<li>Python, data cleaning, automation and dashboard projects</li>
					<li>Tableau, reporting, data visualisation and insight communication</li>
					<li>Docker, Linux, VS Code, Git and technical development workflows</li>
				</ul>
			</section>

			<section>
				<h2 class="section-title">Experience</h2>

				<h3 class="mt-4 text-2xl font-semibold">
					Technical Data Analyst — Profitero
				</h3>
				<p class="text-base opacity-75">August 2025 – Present</p>

				<ul class="mt-4 list-disc pl-6 space-y-2">
					<li>Support accurate eCommerce product data delivery across BAU operations and new client implementations.</li>
					<li>Work with product identifiers, titles, pack sizes, brands, sub-brands, manufacturers and product attributes.</li>
					<li>Use Excel, structured validation and quality checks to improve product data accuracy.</li>
					<li>Track work through JIRA and communicate with stakeholders through Slack and email.</li>
				</ul>
			</section>

			<section>
				<h2 class="section-title">Learning & Development</h2>
				<p class="mt-4">
					I am currently building practical skills in Python, SQL, PostgreSQL, Tableau,
					Docker and Linux, with a focus on data analytics, automation, dashboards and
					Python development.
				</p>
			</section>

		</div>
	</section>
</BaseLayout>