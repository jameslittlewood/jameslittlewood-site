---
import Hero from "@/components/blocks/Hero.astro";
import site from "@/config/site";
import Layout from "@/layouts/Layout.astro";
---

<Layout title={site.meta.title} description={site.meta.description}>
	<div class="animate-in fade-in slide-in-from-bottom-4 mx-auto max-w-2xl p-8 md:p-16">
		<Hero />

		<section class="mt-16 space-y-5">
			<h2 class="text-2xl font-semibold tracking-tight">
				About Me
			</h2>

			<p class="text-lg leading-relaxed text-muted-foreground">
				I’m James Littlewood, a Data Analyst based in Reading, Berkshire.
				I’m interested in using data, analysis and technology to solve problems,
				improve processes and make information easier to understand.
			</p>

			<p class="text-lg leading-relaxed text-muted-foreground">
				I’m currently building my skills in Python, SQL, PostgreSQL, Tableau,
				Docker and Linux, with a focus on practical data analytics, automation
				and dashboard projects.
			</p>

			<p class="text-lg leading-relaxed text-muted-foreground">
				This website is where I share my learning, projects and progress as I
				continue developing towards more advanced data analytics and Python development.
			</p>

			<div class="pt-2">
				<a href="/about" class="font-medium underline underline-offset-4">
					Read more about me
				</a>
			</div>
		</section>
	</div>
</Layout>
