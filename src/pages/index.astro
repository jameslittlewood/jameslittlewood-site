---
import BaseLayout from '../layouts/BaseLayout.astro'
import { SITE_BASE } from '../consts'
import { Icon } from 'astro-icon/components'
---

<BaseLayout>
	<main
		class="app-container flex flex-col gap-8 justify-center py-20 md:py-28 pt-32 md:pt-36 relative"
	>
		<div>
			<h1 class="text-8xl font-bold leading-none">James Littlewood</h1>
		</div>

		<p class="text-2xl max-w-2xl font-light leading-normal">
			I build data analytics projects using Python, SQL, PostgreSQL, Docker and Tableau.
		</p>
	</main>

	<section class="app-container py-16 grid lg:grid-cols-2 gap-16 lg:gap-10">
		<div class="space-y-6">
			<h2 class="section-title">About Me</h2>

			<p class="text-lg max-w-xl pb-4">
				I am a Technical Data Analyst building my skills in Python, SQL,
				PostgreSQL, Docker, Tableau and data dashboard development.
			</p>

			<a class="btn-secondary" href={`${SITE_BASE}/about`}>
				Go to About
				<Icon size={20} name="mdi:arrow-right" />
			</a>
		</div>

		<div class="space-y-6">
			<h2 class="section-title">Get in touch</h2>

			<p class="text-lg max-w-xl">
				Use the button below to contact me by email.
			</p>

			<div class="flex flex-wrap mt-auto space-x-4">
				<a
					class="btn-primary"
					href="mailto:example@email.com"
					target="_blank"
				>
					Get in touch
					<Icon height={20} name="mdi:email" />
				</a>
			</div>
		</div>
	</section>
</BaseLayout>