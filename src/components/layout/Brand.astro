---
import site from "@/config/site";
---

<div class="mt-4 mb-6 md:mt-4 md:mb-10">
  <img
    id="sidebar-gif"
    src="/foulou.gif"
    alt=""
    aria-hidden="true"
    class="mb-4 h-30 w-30 object-contain"
  />

  <div>
    <h1
      data-pagefind-ignore
      class="text-lg font-bold tracking-tight text-foreground md:text-xl"
    >
      {site.meta.title}
    </h1>

    <p class="mt-2 hidden text-xs text-muted-foreground/70 md:block">
      {site.meta.description}
    </p>
  </div>
</div>

<script>
  const gifs = [
    "/ani_lian.gif",
    "/ani_ragnar-ezgif.com-crop.gif",
    "/ani_uku.gif",
    "/foulou.gif",
    "/ichigo.gif",
  ];

  const queueKey = "sidebar-gif-queue";
  const lastGifKey = "sidebar-last-gif";

  function shuffle(items) {
    const shuffled = [...items];

    for (let index = shuffled.length - 1; index > 0; index--) {
      const randomIndex = Math.floor(Math.random() * (index + 1));

      [shuffled[index], shuffled[randomIndex]] = [
        shuffled[randomIndex],
        shuffled[index],
      ];
    }

    return shuffled;
  }

  function getNextGif() {
    let queue = [];
    let lastGif = null;

    try {
      queue = JSON.parse(sessionStorage.getItem(queueKey) || "[]");
      lastGif = sessionStorage.getItem(lastGifKey);
    } catch {
      queue = [];
      lastGif = null;
    }

    if (!Array.isArray(queue) || queue.length === 0) {
      queue = shuffle(gifs);

      if (queue.length > 1 && queue[0] === lastGif) {
        [queue[0], queue[1]] = [queue[1], queue[0]];
      }
    }

    const nextGif = queue.shift();

    try {
      sessionStorage.setItem(queueKey, JSON.stringify(queue));
      sessionStorage.setItem(lastGifKey, nextGif);
    } catch {
      // The GIF still changes even if browser storage is unavailable.
    }

    return nextGif;
  }

  function updateSidebarGif() {
    const gifElement = document.getElementById("sidebar-gif");

    if (!(gifElement instanceof HTMLImageElement)) return;

    gifElement.src = getNextGif();
  }

  // Runs on a normal browser refresh or standard page visit.
  updateSidebarGif();

  // Runs after Astro client-side page navigation, if enabled.
  document.addEventListener("astro:after-swap", updateSidebarGif);
</script>